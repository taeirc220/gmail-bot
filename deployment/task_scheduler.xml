<?xml version="1.0" encoding="UTF-16"?>
<!--
  Gmail Automation Bot — Windows Task Scheduler definition.

  To install:
    schtasks /create /xml "deployment\task_scheduler.xml" /tn "GmailBot"

  To uninstall:
    schtasks /delete /tn "GmailBot" /f

  IMPORTANT: Edit the <WorkingDirectory> and <Command> paths below
  to match your actual project folder before installing.
-->
<Task version="1.2" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">

  <RegistrationInfo>
    <Description>Gmail Automation Bot — monitors inbox, sends notifications, manages newsletters.</Description>
    <Author>GmailBot</Author>
  </RegistrationInfo>

  <Triggers>
    <LogonTrigger>
      <Enabled>true</Enabled>
      <!-- Starts the bot 30 seconds after login to let the network come up -->
      <Delay>PT30S</Delay>
    </LogonTrigger>
  </Triggers>

  <Principals>
    <Principal id="Author">
      <LogonType>InteractiveToken</LogonType>
      <RunLevel>LeastPrivilege</RunLevel>
    </Principal>
  </Principals>

  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <AllowHardTerminate>true</AllowHardTerminate>
    <StartWhenAvailable>true</StartWhenAvailable>
    <RunOnlyIfNetworkAvailable>true</RunOnlyIfNetworkAvailable>
    <ExecutionTimeLimit>PT0S</ExecutionTimeLimit>
    <Hidden>true</Hidden>
    <RestartOnFailure>
      <Interval>PT1M</Interval>
      <Count>3</Count>
    </RestartOnFailure>
    <Enabled>true</Enabled>
  </Settings>

  <Actions Context="Author">
    <Exec>
      <!--
        EDIT THIS PATH: Replace with the full path to launcher.bat on your machine.
        Example: C:\Users\YourName\Documents\gmail-bot\deployment\launcher.bat
      -->
      <Command>C:\Users\taeir\OneDrive\Desktop\gmail bot\deployment\launcher.bat</Command>
      <WorkingDirectory>C:\Users\taeir\OneDrive\Desktop\gmail bot</WorkingDirectory>
    </Exec>
  </Actions>

</Task>
