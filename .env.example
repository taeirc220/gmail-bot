# Gmail OAuth2
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json

# Review server (local Flask on localhost)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
REVIEW_SERVER_SECRET=replace_with_32_char_hex
REVIEW_SERVER_PORT=8080

# Database
DB_PATH=data/gmail_bot.db

# Safety flags
# DRY_RUN=true: bot reads emails but never deletes or unsubscribes anything (Safe Mode)
# Default is ON for new installs — turn it off once you trust the bot's behaviour
DRY_RUN=true
# Set TEST_MODE=true to restrict bot to BotTestInbox label only
TEST_MODE=false

# Quiet hours (24h format, local time)
QUIET_HOURS_START=22
QUIET_HOURS_END=7

# Push notifications to phone via ntfy.sh (free — https://ntfy.sh)
# 1. Install the ntfy app on your phone (Android/iOS)
# 2. Pick a secret topic name (treat it like a password — anyone who knows it can subscribe)
# 3. Set NTFY_TOPIC below and subscribe to the same topic in the app
# Leave blank to use Windows desktop toast notifications instead.
NTFY_TOPIC=
NTFY_URL=https://ntfy.sh

# Dashboard network binding
# 127.0.0.1 = local only (Windows / development)
# 0.0.0.0   = accessible from the internet (cloud server — set this on Oracle Cloud)
DASHBOARD_HOST=127.0.0.1
